
<div class="space-section">
  <!-- Route Header -->
  <div class="title-card">
    <div class="flex flex-row items-center gap-4">
      <div id="star-button">
        <%= button_to @is_starred ? "★" : "☆", star_route_path(@route), method: :post, class: "btn #{@is_starred ? "btn-starred" : "btn-unstarred"}" %>
      </div>
      <h1 class="page-title truncate"><%= "#{@route.short_name} - #{@route.long_name}" %></h1>
      <%# modeTypeIcon %>
    </div>
  </div>

  <!-- Map Section -->
  <div class="card-lg overflow-hidden">
    <div 
      id="map" 
      class="map-responsive"
      data-controller="map"
      data-icon-url="<%= asset_path('vehicle_icon.png') %>"
      data-vehicles="<%= @vehicles.map{|vehicle| {coord: [vehicle.lat, vehicle.lon], bearing: vehicle.bearing} }.to_json %>"
      data-shapes="<%= @shapes.to_json %>"
    ></div>
  </div>

  <!-- Active Vehicles Section -->
  <div class="card-lg">
    <div class="flex items-center mb-4">
      <h2 class="section-title">Vehicles</h2>
      <span class="badge-count">
        <%= Time.now.to_i - Vehicle.timestamp %> seconds ago
      </span>
    </div>

    <% if @vehicles.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @vehicles.each do |vehicle| %>
          <div class="info-card">
            <div class="space-y-2 text-sm">
              <div class="info-card-row">
                <span class="info-card-label">ID</span>
                <span class="info-card-value"><%= vehicle.id %></span>
                <span>|</span>
                <span class="info-card-label">Speed</span>
                <span class="info-card-value"><%= vehicle.speed %> km/h</span>
                <span>|</span>
                <span class="info-card-label">Bearing</span>
                <span class="info-card-value"><%= vehicle.bearing %>&#176</span>
              </div>
              <div class="info-card-row">
                <span class="status-value"><%= "#{vehicle.current_status.capitalize} #{vehicle.stop}" %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <svg class="empty-state-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p>No active vehicles on this route</p>
      </div>
    <% end %>
  </div>
</div>
