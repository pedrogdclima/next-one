<div class="space-section">
  <!-- Page Header -->
  <div class="page-header">
    <div>
      <h1 class="page-title">Routes</h1>
      <p class="page-description">Browse and manage transit routes</p>
    </div>
  </div>

  <!-- Starred Routes Section -->
  <% if @starred_routes.any? %>
    <div id="starred-routes-list" class="grid-cards">
      <% @starred_routes.each do |route_id| %>
        <% route = Route.find(route_id) %>
        <%= link_to route, class: "card-hover-starred" do %>
          <%= render route %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Other routes cards -->
  <%= turbo_frame_tag "other-routes" do %>
    <!-- Buttons to filter routes by mode type -->
    <div id="mode-filter-buttons" class="flex gap-2 my-4">
      <%= link_to "Bus", filter_by_mode_routes_path(mode: "3"), class: "btn-secondary" %>
      <%= link_to "Streetcar", filter_by_mode_routes_path(mode: "0"), class: "btn-secondary" %>
      <%= link_to "Blue Night Network", filter_by_mode_routes_path(mode: "night"), class: "btn-secondary" %>
    </div>
  <% end %>
</div>
