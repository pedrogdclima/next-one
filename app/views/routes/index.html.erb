<div class="space-section">
  <!-- Starred Routes Cards -->
  <h2 class="section-title">Starred Routes</h2>
  <% if @starred_routes.any? %>
    <div id="starred-routes-list" class="grid-cards">
      <% @starred_routes.each do |route_id| %>
        <% route = Route.find(route_id) %>
        <%= link_to route, class: "card-hover-starred" do %>
          <%= render route %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="card">
      <p class="empty-state">Starred routes will be displayed here for quick access!</p>
    </div>
  <% end %>

  <!-- Other routes cards -->
  <div id="other-routes" class="grid grid-cols-2 gap-4 auto-rows-max">
    <div class="grid-routes">
      <h2 class="section-title">Streetcars</h2>
      <% @routes.each do |route| %>
        <% next if Route.ignore.include?(route.id) || @starred_routes.include?(route.id) || route.mode_type != "0" %>
        <%= link_to route, class: "card-hover" do %>
          <%= render route %>
        <% end %>
      <% end %>
    </div>
    <div class="grid-routes">
      <h2 class="section-title">Busses</h2>
      <% @routes.each do |route| %>
        <% next if Route.ignore.include?(route.id) || @starred_routes.include?(route.id) || route.mode_type != "3" %>
        <%= link_to route, class: "card-hover" do %>
          <%= render route %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
