<div class="space-section">
  <!-- Page Header -->
  <div class="page-header">
    <div>
      <h1 class="page-title">Routes</h1>
      <p class="page-description">Browse and manage transit routes</p>
    </div>
  </div>

  <!-- Starred Routes Section -->
  <% if @starred_routes.any? %>
    <div id="starred-routes" class="card-blue">
      <h2 class="section-title-with-icon">
        <svg class="section-title-icon" fill="currentColor" viewBox="0 0 20 20">
          <path d="M5 4a2 2 0 012-2h6a2 2 0 012 2v14l-5-2.5L5 18V4z"></path>
        </svg>
        Starred Routes
      </h2>
      <div id="starred-routes-list" class="grid-cards">
        <% @starred_routes.each do |route_id| %>
          <% route = Route.find(route_id) %>
          <div class="card-hover">
            <%= render route %>
            <%= link_to "View Route", route, class: "link-primary mt-3 inline-flex" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- All Routes Section -->
  <div class="spacing-lg">
    <h2 class="section-title">All Routes</h2>
    <div id="routes" class="grid-cards">
      <% @routes.each do |route| %>
        <% next if @starred_routes.any?(route.id) %>
        <div class="card-hover">
          <%= render route %>
          <%= link_to "View Route", route, class: "link-primary mt-3 inline-flex" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
