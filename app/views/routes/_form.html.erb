<%= form_with(model: route) do |form| %>
  <% if route.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(route.errors.count, "error") %> prohibited this route from being saved:</h2>

      <ul>
        <% route.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :id, style: "display: block" %>
    <%= form.number_field :id %>
  </div>

  <div>
    <%= form.label :short_name, style: "display: block" %>
    <%= form.text_field :short_name %>
  </div>

  <div>
    <%= form.label :long_name, style: "display: block" %>
    <%= form.text_field :long_name %>
  </div>

  <div>
    <%= form.label :mode_type, style: "display: block" %>
    <%= form.text_field :mode_type %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
