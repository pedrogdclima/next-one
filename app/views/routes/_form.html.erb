<%= form_with(model: route, local: true) do |form| %>
  <% if route.errors.any? %>
    <div class="form-error">
      <h2 class="form-error-heading"><%= pluralize(route.errors.count, "error") %> prohibited this route from being saved:</h2>
      <ul class="form-error-list">
        <% route.errors.each do |error| %>
          <li class="form-error-item"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <div class="form-group">
      <%= form.label :id, class: "text-label" %>
      <%= form.number_field :id, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :short_name, "Route Short Name", class: "text-label" %>
      <%= form.text_field :short_name, class: "form-input" %>
    </div>

    <div class="form-group form-grid-full">
      <%= form.label :long_name, "Route Long Name", class: "text-label" %>
      <%= form.text_field :long_name, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :mode_type, "Mode Type", class: "text-label" %>
      <%= form.text_field :mode_type, class: "form-input" %>
    </div>
  </div>

  <div class="form-actions">
    <%= form.submit class: "btn-primary" %>
    <%= link_to "Cancel", routes_path, class: "btn-secondary" %>
  </div>
<% end %>
